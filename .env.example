# Copia este archivo como .env y ajusta los valores para tu entorno local.
# .env está en .gitignore y nunca se versiona.

# Genera una con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# True en desarrollo local, False (o ausente) en producción
DEBUG=True

PG_DB=ispch
PG_USER=postgres
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5432
